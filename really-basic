        <style>
            
            
            body {
                width: 100%;
                height: 100vh;
                margin: 0;
                padding: 0;
                background: {BackgroundColor};
                
                {block:ifBackgroundImage} 
                background-image: url({image:Background Image});
                {/block:ifBackgroundImage} 
                
                flex-direction: column;
                font-family: {font:Body Font};
                font-size: {text:Body Font Size};
                display: flex;
                justify-content: center;
                align-items: center;
                color: {color:Text Color};
                
                {block:ifTopIcon}
                margin-top: 0.4rem;
                {/block:ifTopIcon}
                
                overflow-y: hidden;
            }
            
            #page {
                display: contents;
            }
            
            .box {
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                width: 470px;
                padding-bottom: 0.4rem;
                padding-right: 1rem;
                /*background-color: rgb(190, 218, 236);*/
                overflow: hidden;
                margin-top: 1rem;
            }
            
            
            header {
                width: 100%;
                font-family: "Rubik", sans-serif;
                font-optical-sizing: auto;
                font-style: normal;
                text-align: center;
                color: rgb(57, 113, 153);
            }
            
            .favicon {
                margin-bottom: 0.3rem;
                max-height: 50px;
            }
            
            .banner {
                width: 100%;
                height: 80px;
                object-fit: cover;
                /*border-radius: 10px;*/
                display: none;
            }
            
            {block:ifShowBanner}
            .banner {
                display: block;
            }
            {/block:ifShowBanner}

            .blog-title {
                color: {TitleColor};
                font-family: {TitleFont}, "Helvetica Neue", HelveticaNeue, Arial, sans-serif;
                font-weight: {TitleFontWeight};
                font-size: {text:Blog Title Size}px;
                margin: 0.3rem 0;
                margin-bottom: 0;
            }
            
            .description {
                margin-top: 0.8rem;
                color: {color:Text Color};
                font-size: 11pt;
            }

            .blog-title a,
            .search-no-results,
            .likes-no-likes,
            .related-posts-wrapper > h2,
            .loader .loader-bar,
            .widget-title,
            .tagged-page-cta .tagged-page-cta-desc {
                color: {TitleColor};
            }

            .tagged-page-cta .tagged-page-cta-tag {
                color: {TitleColor};
                border-color: {TitleColor};
            }
            
            h3 {
                margin: 0;
            }

            a {
                color: {AccentColor};
                transition: ease-in-out 0.3s;
            }
            
            .post-reblog-header a, .post-info a, .link a {
                text-decoration: none;
            }
            
            .post-body a {
                color: {AccentColor};
            }
            
            .post-body a:hover {
                color: {color:Hover Color};
            }
            
            .link a {
                color: {AccentColor};
            }
            
            nav {
                width: 100%;
                font-size: 11pt;
            }
            
            nav ul {
                padding-left: 0;
                display: flex;
                justify-content: center;
                margin: 0.4rem 0;
            }
            
            .main {
                display: block;
            }
            
            .nav-item {
                color: {AccentColor};
                display: inline;
                transition: ease-in-out 0.4s;
                margin-right: 0.3rem;
                cursor: pointer;
            }
            
            .nav-item:last-child {
                margin-right: 0;
                border-right: none;
            }
            
            .nav-item a {
                color: {AccentColor};
                font-weight: 800;
            }
            
            .nav-item a:hover {
                color: {color:Hover Color};
            }
            
            #posts {
                margin: 0;
                width: 100%;
            }
            
            #container {
                width: 100%;
                height:  calc(100vh - 180px {block:ifShowDescription} - 30px {/block:ifShowDescription} {block:ifTopIcon} - 30px {/block:ifTopIcon});
                overflow-y: auto;
                padding: 0;
                padding-right: 0.7rem;
            }
            
            .posts-tagged {
                color: {AccentColor};
                margin: 0.5rem 0;
                font-size: 120%;
            }
            
            .post-wrapper {
                padding: 1rem;
                border: {text:Post Border Weight} {select:Post Border} {color:Container Border Color};
                {block:ifNotRoundedCorner}
                border-radius: inherit;
                {/block:ifNotRoundedCorner}
                background-color: white;
                margin-bottom: 1.6rem;
                background-color: {color:Container Color};
            }
            
            .post-wrapper:last-child {
                margin-bottom: 0.1rem;
            }
            
            .post img {
                width: 100%;
                height: 100%;
            }
            
            .post-avatar {
                float: left;
                margin-right: 0.4rem;
            }
            
            .post-avatar img {
                width: 20px;
            }
            
            .npf_row {
                margin: 0;
            }
            
            .literal-link {
                display: block;
                border: {AccentColor} solid 1px;
                {block:ifRoundedCorner}
                border-radius: 8px;
                {/block:ifRoundedCorner}
                margin-bottom: 1rem;
                min-height: 50%;
                padding: 0.7rem;
            }
            
            .post-wrapper .npf-link-block {
                border: {color:Container Border Color} solid 1px;
                {block:ifRoundedCorner}
                border-radius: 8px;
                {/block:ifRoundedCorner}
            }
            
             .post-wrapper .npf-link-block .bottom {
                 padding: 0.7rem;
                 color: {color:Text Color};
             }
            
            .host {
                opacity: 0.6;
            }
            
            
            iframe .audio-container {
                height: 80px;
            }
        
            iframe .spotify_audio_player {
                height: 80px;
            }
            
            .asker-section {
                display: flex;
                flex-direction: row-reverse;
                margin-bottom: 0.9rem;
            }
            
            .asker-avatar {
                margin-left: 0.5rem;
            }
            
            .question {
                border: 1px solid {AccentColor};
                width: 100%;
                {block:ifRoundedCorner}
                border-radius: 8px;
                {/block:ifRoundedCorner}
                padding: 0.5rem;
            }
            
            .question p:last-child {
                margin-bottom: 0;
            }
            
            .answerer img, .asker img {
                width: 20px;
                margin-right: 0.2rem;
            }
            
            .answerer a {
                text-decoration: none;
            }
            
            .post-reblog-content {
                margin-top: 0.9rem;
            }
            
            .post-wrapper .rebloggedfrom {
                color: {AccentColor};
                text-align: right;
            }
            
            .post-wrapper .rebloggedfrom a:hover {
                color: {color:Hover Color};
            }
            
            .post-info {
                margin-top: 1rem;
                color: {color:Text Color};
            }
            
            
            .date-reblogged-section {
                display: flex;
                justify-content: space-between;
                align-items: center;
                
                {block:ifNotShowPostTags}
                margin-bottom: 0.3rem;
                {/block:ifNotShowPostTags}
            }
            
            .date {
                font-size: 80%;
                text-align: right;
            }
            
            .tag-section {
                margin: 0.3rem auto;
                {block:ifNotShowPostTags}
                display: none;
                {/block:ifNotShowPostTags}
            }
            
            
            .tag-section a {
                color: {color:Text Color};
                opacity: 0.6;
            }
            
            .tag-link {
                margin-right: 0.4rem;
            }
            
            .note-count {
                float: left;
                color: {color:Text Color};
            }
            
            .post-controls {
                color: {AccentColor};
                transition: ease-in-out 0.3s;
            }
            
            .post-controls .control .like_button {
                transition: ease-in-out 0.3s;
            }
            
            .post-controls .control .like_button:hover, .post-controls .control .reblog_button:hover, .post-controls .control .share:hover {
                color: {color:Hover Color};
            }
            
            .post-controls .controls-wrapper  {
                margin-right: 0;
            }
            
            blockquote, blockquote.npf_indented {
                padding-left: 1em;
                margin-left: 0;
                border-left: 1px solid {AccentColor};
            }
            
            .notes .note {
                margin-bottom: 0.6rem;
            }
            
            .notes .note:last-child {
                margin-bottom: 0;
                margin-top: 0.8rem;
            }
            
            .notes .note span a:hover {
                color: {color:Hover Color};
            }
            
            ::-webkit-scrollbar {
                width: 10px;
            }
            
            ::-webkit-scrollbar-thumb {
                background-color: {AccentColor};
                border-radius: 4px;
                transition: ease-in-out 0.3s;
            }
            
            ::-webkit-scrollbar-thumb:hover {
                background-color: {color:Hover Color};
            }
            
            ::-webkit-scrollbar-track {
                padding-left: 1px;
            }
            
            {block:IfEndlessScrolling}
            footer {
                display: none;
            }
            
            .box {
                padding-bottom: 1.4rem;
            }
            {/block:IfEndlessScrolling}
            
            #footer {
                padding-top: 15px;
                min-width: 110px;
            }
            
            #pagination a {
                margin-bottom: 0;
                margin-top: 0rem;
            }
            
            #pagination .bg {
                opacity: 1;
                {block:ifNotRoundedCorner}
                border-radius: 0;
                {/block:ifNotRoundedCorner}
            }

            #pagination a,
            .nav-wrapper .nav-item .label {
                color: {color:Container Border Color};
            }

            #pagination a.next:after {
                border-left-color: {color:Container Border Color};
                right: 12px;
                top: 6px;
            }

            #pagination a.previous:after {
                border-right-color: {color:Container Border Color};
                left: 12px;
                top: 6px;
            }

            .header-image.cover {
                background-image: url({HeaderImage});
            }

            .user-avatar {
                background-color: {BackgroundColor};
                border-color: {BackgroundColor};
            }

            .avatar-style-square .user-avatar {
                -webkit-box-shadow: 0 0 0 4px {BackgroundColor};
                box-shadow: 0 0 0 4px {BackgroundColor};
            }

            .no-header-image .logo-wrapper,
            .contain-header-image .logo-wrapper {
                color: {AccentColor};
            }

            /* Adjust logo for light accents on light backgrounds */
            .light-on-light.no-header-image .logo-wrapper,
            .light-on-light.contain-header-image .logo-wrapper {
                color: #444;
            }

            /* Adjust logo for dark accents on dark backgrounds */
            .dark-on-dark.no-header-image .logo-wrapper,
            .dark-on-dark.contain-header-image .logo-wrapper {
                color: #fff;
            }

            /* Logged-out compact Tumblr iframe */
            .tmblr-iframe-compact .tmblr-iframe--unified-controls {
                min-width: 100%;
                background-color: rgba(0,0,0,0);
            }

            /* Sticky nav colors */
            .nav-fixed {
                background-color: {BackgroundColor};
            }

            .nav-responsive .inline-nav::after {
                background-image: linear-gradient(left, rgba({RGBBackgroundColor}, 0) 0%, rgba({RGBBackgroundColor},1) 100%);
                background-image: -webkit-linear-gradient(left, rgba({RGBBackgroundColor}, 0) 0%, rgba({RGBBackgroundColor},1) 100%);
                background-image: -moz-linear-gradient(left, rgba({RGBBackgroundColor}, 0) 0%, rgba({RGBBackgroundColor},1) 100%);
                background-image: -ms-linear-gradient(left, rgba({RGBBackgroundColor}, 0) 0%, rgba({RGBBackgroundColor},1) 100%);
                background-image: -o-linear-gradient(left, rgba({RGBBackgroundColor}, 0) 0%, rgba({RGBBackgroundColor},1) 100%);
            }

            @media screen and (max-device-width: 568px) {
                .header-image.cover {
                    background-image: url({HeaderImage-640});
                    -webkit-background-size: cover;
                    background-size: cover;
                }

                .avatar-style-square .user-avatar {
                    -webkit-box-shadow: 0 0 0 3px {BackgroundColor};
                    -moz-box-shadow: 0 0 0 3px {BackgroundColor};
                    box-shadow: 0 0 0 3px {BackgroundColor};
                }

            }

            /* Custom CSS */
            {CustomCSS}
        </style>
    </head>
